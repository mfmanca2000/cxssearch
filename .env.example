# ─── Active Directory / LDAP ──────────────────────────────────────────────────
LDAP_URL=ldap://your-dc.company.com:389
# For LDAPS (TLS): ldaps://your-dc.company.com:636

# Service account that has read access to Active Directory
LDAP_BIND_DN=CN=svc-search,OU=ServiceAccounts,DC=company,DC=com
LDAP_BIND_PASSWORD=YourServiceAccountPassword

# Root DN to start tree navigation from
LDAP_BASE_DN=DC=company,DC=com

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Cache ────────────────────────────────────────────────────────────────────
# How long to cache user lists per OU, in seconds
CACHE_TTL=300

# ─── Mock mode ────────────────────────────────────────────────────────────────
# Set to "true" to run without a real AD server (uses built-in demo data)
MOCK_MODE=true

# ─── OAuth2 / Corporate SSO ───────────────────────────────────────────────────
OAUTH_CLIENT_ID=your-client-id
OAUTH_CLIENT_SECRET=your-client-secret
OAUTH_AUTHORIZATION_URL=https://sso.company.com/oauth/authorize
OAUTH_TOKEN_URL=https://sso.company.com/oauth/token
OAUTH_USERINFO_URL=https://sso.company.com/userinfo
OAUTH_LOGOUT_URL=https://sso.company.com/logout.do
OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/callback
OAUTH_SCOPE=openid,profile,email


VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=